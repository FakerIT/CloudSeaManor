root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{cpp,hpp,h,cc,cxx,hh}]
indent_style = space
indent_size = 4

[*.{md,txt,json,yml,yaml,csv,tmx,cfg}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.sln]
end_of_line = crlf

[*.{vcxproj,vcxproj.filters,props}]
end_of_line = crlf
