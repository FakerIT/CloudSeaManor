    {
      "id": "ning_h1_peace",
      "speaker": "宁安",
      "text": "哈哈，你也是个懂生活的人。现在懂发呆的人不多了。",
      "choices": [
        {
          "id": "choice_end",
          "text": "以后我也来发呆。",
          "next_node_id": "ning_h1_end"
        }
