      "favor_max": 999,
      "season": "",
      "time_of_day": "",
      "weather": "",
      "heart_min": 0,
      "heart_max": 10
    },
    {
      "id": "yan_farewell_3",
      "text": "缘尽则散，$[PLAYER_NAME]$。他日有缘再会。",
      "favor_min": 0,
      "favor_max": 999,
      "season": "",
      "time_of_day": "",
      "weather": "",
      "heart_min": 0,
      "heart_max": 10
    },
    {
      "id": "yan_farewell_high",
      "text": "$[PLAYER_NAME]$，望你修行路上不忘本心。",
