      "weather": "",
      "heart_min": 0,
      "heart_max": 10
    },
    {
      "id": "yan_farewell_night",
      "text": "夜深了，$[PLAYER_NAME]$。当早入眠，顺应天时。",
      "favor_min": 0,
      "favor_max": 999,
      "season": "",
      "time_of_day": "夜晚",
