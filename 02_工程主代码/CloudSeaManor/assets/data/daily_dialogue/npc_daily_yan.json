      "favor_max": 999,
      "season": "",
      "time_of_day": "",
      "weather": "",
      "heart_min": 4,
      "heart_max": 10
    },
    {
      "id": "yan_farewell_morning",
      "text": "晨时已过，$[PLAYER_NAME]$。当珍惜光阴。",
      "favor_min": 0,
      "favor_max": 999,
      "season": "",
      "time_of_day": "清晨",
      "weather": "",
