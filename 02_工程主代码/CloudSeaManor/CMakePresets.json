{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "environment": {
        "SFML_ROOT": "${sourceDir}/../../03_参考与第三方资源/01_SFML引擎/SFML/SFML-3.0.2"
      },
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CLOUDSEAMANOR_ENABLE_WARNINGS": "ON"
      }
    },
    {
      "name": "vs2022-x64",
      "displayName": "Visual Studio 2022 x64",
      "inherits": "base",
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/vs2022-x64"
      }
    },
    {
      "name": "vs2022-x64-tests",
      "displayName": "Visual Studio 2022 x64 (Tests)",
      "inherits": "vs2022-x64",
      "cacheVariables": {
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "vs2022-x64-debug",
      "displayName": "Visual Studio 2022 x64 Debug",
      "inherits": "vs2022-x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "vs2022-x64-release",
      "displayName": "Visual Studio 2022 x64 Release",
      "inherits": "vs2022-x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-debug",
      "displayName": "Build Debug",
      "configurePreset": "vs2022-x64",
      "configuration": "Debug"
    },
    {
      "name": "build-debug-tests",
      "displayName": "Build Debug (Tests)",
      "configurePreset": "vs2022-x64-tests",
      "configuration": "Debug"
    },
    {
      "name": "build-release",
      "displayName": "Build Release",
      "configurePreset": "vs2022-x64",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "test-debug",
      "displayName": "Run Tests (Debug)",
      "configurePreset": "vs2022-x64-tests",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
