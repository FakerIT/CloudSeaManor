# =============================================================================
# CloudSeaManor EditorConfig
# =============================================================================
# 编辑器统一配置文件，支持 VS Code、CLion、VS 等主流编辑器
# https://editorconfig.org

# 根目录
root = true

# =============================================================================
# 通配符
# =============================================================================

# 所有文件
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown 文件
[*.md]
trim_trailing_whitespace = false
indent_size = 4
indent_style = space

# =============================================================================
# C++ 文件
# =============================================================================

[*.{cpp,hpp,cc,hh,cxx,hxx}]
indent_size = 4
indent_style = space
max_line_length = 100

# =============================================================================
# JSON/YAML 配置文件
# =============================================================================

[*.{json,yaml,yml}]
indent_size = 2
indent_style = space

# =============================================================================
# CMake 文件
# =============================================================================

[CMakeLists.txt]
indent_size = 4
indent_style = space

[*.cmake]
indent_size = 4
indent_style = space

# =============================================================================
# Shell 脚本
# =============================================================================

[*.sh]
indent_size = 4
indent_style = space
end_of_line = lf

# =============================================================================
# Windows 批处理文件
# =============================================================================

[*.bat]
indent_size = 4
indent_style = space
end_of_line = crlf

# =============================================================================
# XML 文件
# =============================================================================

[*.xml]
indent_size = 2
indent_style = space

# =============================================================================
# TMX 地图文件
# =============================================================================

[*.{tmx,tsx}]
indent_size = 4
indent_style = space
max_line_length = off

# =============================================================================
# 忽略文件
# =============================================================================

# Git 文件
[.git/**]
charset = unspecified
indent_style = unspecified

# 二进制文件
[*.{png,jpg,jpeg,gif,ico,exe,dll,zip,7z}]
charset = binary
end_of_line = lf
insert_final_newline = false
trim_trailing_whitespace = false
